@model List<Lab2MVC.Models.StudentDbWork>

@{
    ViewBag.Title = "Все работы";
}

<h2>Все работы</h2>

@if (Model.Count == 0)
{
    <p>Пока нет введённых данных.</p>
}
else
{
    <table border="1">
        <tr>
            <th>Идентификатор</th>
            <th>ФИО студента</th>
            <th>Группа</th>
            <th>Тема проекта</th>
            <th>Дата сдачи</th>
            <th>Оценка</th>
            <th>Есть защита</th>
        </tr>

        @for (int i = 0; i < Model.Count; i++)
        {
            <tr>
                <td>@Model[i].Id</td>
                <td>@Model[i].StudentName</td>
                <td>@Model[i].GroupName</td>
                <td>@Model[i].ProjectTopic</td>
                <td>@Model[i].SubmissionDate</td>
                <td>@Model[i].Score</td>
                <td>@Model[i].IsDefended</td>
            </tr>
        }
    </table>
}